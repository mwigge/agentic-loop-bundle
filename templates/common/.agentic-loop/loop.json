{
  "version": 1,
  "openspec": {
    "version": "1.4.1",
    "required": true
  },
  "limits": {
    "max_attempts": 3,
    "agent_timeout_seconds": 1800,
    "verify_timeout_seconds": 900
  },
  "verification": {
    "command": "./.agentic-loop/bin/verify.sh",
    "test_command": "./.agentic-loop/bin/test.sh"
  },
  "review": {
    "enabled": true,
    "required": false
  },
  "telemetry": {
    "service_name": "agentic-loop",
    "capture_prompts": false,
    "capture_responses": false
  }
}
